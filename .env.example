# ─── Frontend (Vite) ──────────────────────────────────────────────────────
# Base URL of the Meridian API server.
VITE_API_URL=http://localhost:4000

# ─── Backend (Express + MongoDB) ──────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:5173

# MongoDB connection string (local default shown).
MONGODB_URI=mongodb://127.0.0.1:27017/meridian

# Secret used to sign session JWTs — set to a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# ─── Admin panel (/admin) ─────────────────────────────────────────────────
# Standalone login for the read-only admin dashboard. Independent of user
# accounts. CHANGE THESE before deploying — anyone with them sees all data.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# Optional — separate secret for signing the admin session (falls back to JWT_SECRET).
ADMIN_JWT_SECRET=

# ─── Google OAuth (optional) ──────────────────────────────────────────────
# From https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ─── Email / SMTP (optional) ──────────────────────────────────────────────
# Leave blank in development — OTP codes and reset links are logged to the
# server console instead. Fill these in to send real email via Nodemailer.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Meridian <no-reply@meridian.local>
