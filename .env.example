# ─── Frontend (Vite) ──────────────────────────────────────────────────────
# Base URL of the Meridian API server.
VITE_API_URL=http://localhost:4000

# ─── Sanity CMS (content the client edits at /studio) ─────────────────────
# Create a free project at https://sanity.io, then paste the Project ID here.
# Leave blank to keep using the site's built-in (hardcoded) fallback content.
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2025-01-01
# One-time content seeding only (scripts/seedSanity.mjs). Create an Editor token
# at sanity.io → API → Tokens. NEVER commit a real token.
SANITY_WRITE_TOKEN=

# ─── Backend (Express + MongoDB) ──────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:5173

# MongoDB connection string (local default shown).
MONGODB_URI=mongodb://127.0.0.1:27017/meridian

# Secret used to sign session JWTs — set to a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# ─── Admin panel (/admin) ─────────────────────────────────────────────────
# Standalone login for the read-only admin dashboard. Independent of user
# accounts. CHANGE THESE before deploying — anyone with them sees all data.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# Optional — separate secret for signing the admin session (falls back to JWT_SECRET).
ADMIN_JWT_SECRET=

# ─── Google OAuth (optional) ──────────────────────────────────────────────
# From https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ─── Email / SMTP ─────────────────────────────────────────────────────────
# Required for brochure & PDF delivery — files are attached to the email.
# and resource downloads. Until configured, messages are logged to the server
# console instead of being sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Menler <no-reply@menler.in>
